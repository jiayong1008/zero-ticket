# Database configuration (SQLite for local metadata)
DATABASE_URL=sqlite:///./zeroticket.db

# Encryption key for securing replica DB credentials at rest.
# Must be a 32 URL-safe base64-encoded bytes string.
ENCRYPTION_KEY=tVv5F3a7-wM7o79P56s4lCq8z46p9u8r5y6_1A3B-CE=

# External LLM Keys (Configure if using Gemini or OpenAI)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Commercial Self-Hosted Configuration
# Set an admin passphrase to protect your dashboard configurations inside your network.
# Leave empty to run in development mode (passphrase disabled).
ADMIN_PASSWORD=

# Your ZeroTicket commercial license key (must start with zt_license_)
LICENSE_KEY=

# Custom Local LLM Endpoint (e.g. Ollama or vLLM)
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
